@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();

    var isDashboard = currentController == "Home";
    // Cek apakah controller-nya adalah VehicleStatus
    var isVehicleStatus = currentController == "VehicleStatus";
    var isReports = currentController == "Reports";
    var isSettings = currentController == "Settings";
}

<aside class="main-sidebar sidebar-dark-primary elevation-0">
    <a href="/" class="brand-link">
        <img src="~/adminlte/dist/img/AdminLTELogo.png"
             alt="Logo"
             class="brand-image img-circle"
             style="opacity: .9" />
        <span class="brand-text font-weight-bold">BSU SYSTEM</span>
    </a>

    <div class="sidebar px-0">

        <!-- USER PANEL -->
        <div class="user-panel mt-3 pb-3 mb-3 d-flex align-items-center px-3">
            <div class="image">
                <img src="~/adminlte/dist/img/user2-160x160.jpg"
                     class="img-circle elevation-2"
                     alt="User Image" />
            </div>
            <div class="info">
                <a href="#" class="d-block font-weight-bold" style="font-size: 0.9rem;">Alexander Pierce</a>
                <span class="text-xs text-success">
                    <i class="fas fa-circle font-size-xs mr-1"></i> Online
                </span>
            </div>
        </div>

        <!-- SEARCH -->
        <div class="form-inline px-3">
            <div class="input-group" data-widget="sidebar-search">
                <input class="form-control form-control-sidebar" type="search" placeholder="Quick Search...">
                <div class="input-group-append">
                    <button class="btn btn-sidebar">
                        <i class="fas fa-search fa-fw text-xs"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- MENU -->
        <nav class="mt-3">
            <ul class="nav nav-pills nav-sidebar flex-column"
                data-widget="treeview"
                role="menu"
                data-accordion="false">

                <li class="nav-header">MAIN NAVIGATION</li>

                <!-- DASHBOARD -->
                <li class="nav-item">
                    <a href="/" class="nav-link @(isDashboard ? "active" : "")">
                        <i class="nav-icon fas fa-th-large"></i>
                        <p>Dashboard Overview</p>
                    </a>
                </li>

                <!-- VEHICLE STATUS -->
                <li class="nav-item @(isVehicleStatus ? "menu-open" : "")">
                    <a href="#" class="nav-link @(isVehicleStatus ? "active" : "")">
                        <i class="nav-icon fas fa-truck"></i>
                        <p>
                            Vehicle Status
                            <i class="right fas fa-angle-left"></i>
                        </p>
                    </a>

                    <ul class="nav nav-treeview">
                        <li class="nav-item">
                            <!-- Arahkan ke Controller: VehicleStatus, Action: TruckRegistration -->
                            <a asp-controller="VehicleStatus" asp-action="TruckRegistration"
                               class="nav-link @(currentAction == "TruckRegistration" ? "active" : "")">
                                <i class="far fa-circle nav-icon"></i>
                                <p>Truck Registration</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <!-- Arahkan ke Controller: VehicleStatus, Action: AlreadyWeighed -->
                            <a asp-controller="VehicleStatus" asp-action="AlreadyWeighed"
                               class="nav-link @(currentAction == "AlreadyWeighed" ? "active" : "")">
                                <i class="far fa-circle nav-icon"></i>
                                <p>Already Weighed</p>
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-header">REPORTS & ANALYTICS</li>

                <!-- REPORT -->
                <li class="nav-item">
                    <a href="/Reports/Daily" class="nav-link @(isReports ? "active" : "")">
                        <i class="nav-icon fas fa-file-alt"></i>
                        <p>Daily Tonnage Report</p>
                    </a>
                </li>

                <!-- SETTINGS -->
                <li class="nav-item">
                    <a href="/Settings" class="nav-link @(isSettings ? "active" : "")">
                        <i class="nav-icon fas fa-cog"></i>
                        <p>System Settings</p>
                    </a>
                </li>

            </ul>
        </nav>
    </div>
</aside>
